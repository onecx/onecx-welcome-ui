{
  "name": "onecx-welcome-ui",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "contributors": [
    "OneCX Development Team <onecx_dev@1000kit.org>"
  ],
  "config": {
    "openapiYaml": "src/assets/api/openapi-bff.yaml",
    "openapiOutput": "src/app/shared/generated"
  },
  "scripts": {
    "build": "ng build",
    "postbuild": "mv \"$(find dist/onecx-welcome-ui -maxdepth 1 -type f -name 'styles.*.css' | head -n 1)\" dist/onecx-welcome-ui/styles.css",
    "check": "ng lint --cache=true && npx prettier -c --cache .",
    "clean": "npm cache clean --force && ng cache clean && rm -rf *.log dist reports .angular .eslintcache ./node_modules/.cache/prettier/.prettier-cache",
    "lint": "ng lint --cache=true",
    "format": "ng lint --fix",
    "eslint": "eslint --quiet --ext .js,.ts src",
    "browser": "npx browserslist",
    "prepare": "husky || true",
    "start": "ng serve --configuration=development --proxy-config=proxy.conf.js",
    "test": "ng test",
    "test:ci": "ng test --watch=false --browsers=ChromeHeadless --code-coverage",
    "karma": "rm -rf reports && npm run test:ci",
    "sonar": "npx sonar-scanner",
    "apigen-cleanup": "rm -rf $npm_package_config_openapiOutput",
    "apigen-format": "npx prettier $npm_package_config_openapiYaml --write && npx prettier $npm_package_config_openapiOutput/**/* --write",
    "apigen-generate": "openapi-generator-cli generate -i $npm_package_config_openapiYaml -g typescript-angular -c apigen.yaml -o $npm_package_config_openapiOutput --type-mappings=AnyType=object,set=Array",
    "apigen": "npm run apigen-cleanup && npm run apigen-generate && npm run apigen-format"
  },
  "husky": {
    "hooks": {
      "pre-commit": "pretty-quick --staged"
    }
  },
  "dependencies": {
    "@angular-architects/module-federation": "^19.0.3",
    "@angular/animations": "^19.2.21",
    "@angular/cdk": "^19.2.19",
    "@angular/common": "^19.2.21",
    "@angular/compiler": "^19.2.21",
    "@angular/core": "^19.2.21",
    "@angular/elements": "^19.2.21",
    "@angular/forms": "^19.2.21",
    "@angular/platform-browser": "^19.2.21",
    "@angular/platform-browser-dynamic": "^19.2.21",
    "@angular/router": "^19.2.21",
    "@ngneat/error-tailor": "^5.0.1",
    "@ngneat/until-destroy": "^10.0.0",
    "@ngrx/effects": "^19.2.1",
    "@ngrx/router-store": "^19.2.1",
    "@ngx-translate/core": "^16.0.0",
    "@ngx-translate/http-loader": "^8.0.0",
    "@onecx/accelerator": "^6.23.2",
    "@onecx/angular-accelerator": "^6.23.2",
    "@onecx/angular-auth": "^6.23.2",
    "@onecx/angular-integration-interface": "^6.23.2",
    "@onecx/angular-remote-components": "^6.23.2",
    "@onecx/angular-testing": "^6.23.2",
    "@onecx/angular-utils": "^6.23.2",
    "@onecx/angular-webcomponents": "^6.23.2",
    "@onecx/integration-interface": "^6.23.2",
    "@primeng/themes": "^19.0.5",
    "@webcomponents/webcomponentsjs": "^2.8.0",
    "chart.js": "^4.4.3",
    "d3-scale-chromatic": "^3.1.0",
    "file-saver": "^2.0.5",
    "keycloak-js": "^25.0.6",
    "primeflex": "^4.0.0",
    "primeicons": "^7.0.0",
    "primeng": "^19.1.4",
    "rxjs": "7.8.1",
    "ts-semaphore": "^1.0.0",
    "tslib": "^2.8.1",
    "zone.js": "^0.15.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.21",
    "@angular-devkit/core": "^19.2.21",
    "@angular-devkit/schematics": "^19.2.21",
    "@angular-eslint/builder": "^19.2.21",
    "@angular-eslint/eslint-plugin": "^19.2.21",
    "@angular-eslint/eslint-plugin-template": "^19.2.21",
    "@angular-eslint/schematics": "^19.2.21",
    "@angular-eslint/template-parser": "^19.2.21",
    "@angular/cli": "^19.2.21",
    "@angular/compiler-cli": "^19.2.21",
    "@angular/language-service": "^19.2.21",
    "@commitlint/cli": "^19.6.1",
    "@commitlint/config-conventional": "^19.5.0",
    "@onecx/angular-standalone-shell": "^6.23.2",
    "@openapitools/openapi-generator-cli": "^2.18.4",
